LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret
# Must match the worker registration in app/agent.py (default: healthcare-agent)
LIVEKIT_AGENT_NAME=healthcare-agent
DEEPGRAM_API_KEY=your_key
CARTESIA_API_KEY=your_key
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# Must match the deployment *name* in Azure AI Studio (Deploy models), not only the model family.
# Alias: AZURE_OPENAI_DEPLOYMENT_NAME is also read if AZURE_OPENAI_DEPLOYMENT is unset.
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
OPENAI_API_KEY=your_key
